# Server Configuration
PORT=3000

# CORS - Set to your production domain in production
CORS_ORIGIN=*

# Groq AI Configuration (required for bot AI chat)
# Get a free API key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT=12000

# Bot Configuration
NUM_BOTS=5
CLEANUP_INTERVAL=60000

# Admin panel key (optional)
ADMIN_KEY=

# Webhook / push notifications (optional)
JOIN_WEBHOOK_URL=
CASHOUT_NTFY_URL=

# PayPal (optional)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
